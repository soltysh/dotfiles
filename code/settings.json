{
    "breadcrumbs.enabled": false,
    "cSpell.enabled": true,
    "cSpell.userWords": [
        "conformant",
        "kubernetes",
        "mitigations",
        "nightlies",
        "preconfigured",
        "quantile",
        "subresources",
        "untrusted"
    ],
    "editor.fontFamily": "Fira Code",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.letterSpacing": 0,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [
        80,
        120
    ],
    "editor.stickyScroll.enabled": true,
    "editor.tabCompletion": "on",
    "explorer.confirmDelete": false,
    "explorer.decorations.badges": false,
    "explorer.decorations.colors": false,
    "extensions.ignoreRecommendations": true,
    "files.enableTrash": false,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/*.pid": true,
        "**/*.pyc": true,
        "**/*.swp": true,
        "**/.env": true,
        "**/.tmp": true,
        "**/__pycache__": true,
        "**/_output": true,
        "**/.vscode": true
    },
    "files.watcherExclude": {
        "**/vendor/**": true
    },
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    "security.workspace.trust.untrustedFiles": "open",
    "window.menuBarVisibility": "toggle",
    "window.title": "${dirty}${activeEditorMedium}${separator}${rootName}",
    "window.titleBarStyle": "custom",
    "window.restoreWindows": "none",
    "workbench.colorTheme": "Monokai Dark Soda",
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.showIcons": false,
    "workbench.editor.untitled.hint": "hidden",
    "workbench.iconTheme": "vs-minimal",
    "workbench.startupEditor": "none",
    "zenMode.hideLineNumbers": false,
    "go.coverOnTestPackage": false,
    "go.formatTool": "gofmt",
    "go.lintOnSave": "off",
    "go.toolsManagement.autoUpdate": true,
    "go.vetOnSave": "off",
    "[go]": {
        "editor.snippetSuggestions": "none",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "never"
        }
    },
    "gopls": {
        "ui.completion.usePlaceholders": true
    },
    "git.mergeEditor": false,
    "calva.prettyPrintingOptions": {
        "printEngine": "pprint",
        "enabled": true,
        "width": 120,
        "maxLength": 50
    },
    "[python]": {
        "editor.formatOnType": true
    },
    "workbench.activityBar.location": "hidden",
    "workbench.editor.empty.hint": "hidden",
    "diffEditor.hideUnchangedRegions.enabled": true,
    "redhat.telemetry.enabled": false,
    "yaml.schemas": {
        "https://raw.githubusercontent.com/zarf-dev/zarf/main/zarf.schema.json": "zarf.yaml",
        "https://raw.githubusercontent.com/defenseunicorns/maru-runner/refs/heads/main/tasks.schema.json": "tasks.yaml"
    },
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "chat.viewSessions.enabled": false
}
